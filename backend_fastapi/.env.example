# ============================================
# Project Quote System - 后端环境变量模板
# 复制: cp backend_fastapi/.env.example backend_fastapi/.env
# 然后填入真实值, 启动后端即可生效
# ============================================

# ----- 数据库 (PostgreSQL) -----
# 默认值硬编码在 core/config.py:8, 推荐用环境变量覆盖
DATABASE_URL=postgresql://postgres:***@10.60.100.3:5432/quotation_db

# ----- JWT 密钥 (生产必改) -----
# 默认值: dev-secret-key-change-in-production (不安全!)
SECRET_KEY=your-flask-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# ----- LLM 主路径 (MiniMax) -----
# API 密钥 (主)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01
# 备用域名
MINIMAX_API_HOST=https://api.minimaxi.com

# ----- LLM Fallback (DeepSeek) -----
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ----- Redis 缓存 (可选, 不可用时自动降级到内存) -----
REDIS_URL=redis://localhost:6379/0
CACHE_NAMESPACE=pqs
CACHE_DEFAULT_TTL=30
# 设 true 禁用缓存 (调试用)
CACHE_DISABLED=false

# ----- Debug 端点 (GET /api/_debug/cache-stats) -----
# 需要这个 token 才能访问 debug 端点, 生产请改成强密码
DEBUG_TOKEN=hermes-debug-2024

# ----- 兼容变量 (可选, 给旧代码用) -----
# 如果同时设了 LLM_API_KEY 和 MINIMAX_API_KEY, MiniMax 优先
# 建议直接用 MINIMAX_API_KEY, 不要再设 LLM_API_KEY
