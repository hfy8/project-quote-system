# ============================================
# Project Quote System - Docker 环境变量
# 复制: cp deploy/.env.example deploy/.env
# 编辑填入后: cd deploy && ./docker-deploy.sh up
# ============================================

# --- 数据库 (Docker 容器内 db 服务) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PORT_HOST=5432
POSTGRES_DB=quotation_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=*** --- LLM 主路径 (MiniMax) ---
MINIMAX_API_KEY=你...1
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-Text-01
LLM_API_KEY=*** --- LLM Fallback (DeepSeek) ---
DEEPSEEK_API_KEY=你...t
# --- 鉴权密钥 ---
JWT_SECRET_KEY=随...n
SECRET_KEY=*** --- 运行参数 ---
UVICORN_WORKERS=2
FRONTEND_PORT=80
# --- 可选：跳过建表（用已有数据时设为 true）---
SKIP_DB_INIT=false
