# ============================================
# Project Quote System - Docker 环境变量
# 复制: cp deploy/.env.example deploy/.env
# 编辑填入后: cd deploy && ./docker-deploy.sh up
# ============================================

# --- 数据库 (Docker 容器内 db 服务) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PORT_HOST=5432
POSTGRES_DB=quotation_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# --- LLM 主路径 (MiniMax) ---
MINIMAX_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-Text-01
LLM_API_KEY=same_as_minimax_or_separate

# --- LLM Fallback (DeepSeek) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- 鉴权密钥 ---
JWT_SECRET_KEY=change-in-production-32-chars-min
SECRET_KEY=change-in-production-32-chars-min

# --- 运行参数 ---
UVICORN_WORKERS=2
FRONTEND_PORT=80

# --- Redis (可选, 调试时设 REDIS_PORT_HOST=6379 暴露给宿主机) ---
REDIS_PORT_HOST=

# --- 可选: 跳过建表 (用已有数据时设为 true) ---
SKIP_DB_INIT=false
