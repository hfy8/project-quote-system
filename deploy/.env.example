# ============================================
# Project Quote System - Docker 环境变量
# 复制此文件: cp deploy/.env.example deploy/.env
# 编辑 .env 填入真实密码/密钥后：
#   cd deploy && ./docker-deploy.sh up
# ============================================

# --- 数据库 (远程 PostgreSQL 10.60.100.3) ---
POSTGRES_HOST=10.60.100.3
POSTGRES_PORT=5432
POSTGRES_DB=quotation_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=你的数据库密码

# --- LLM 主路径 (MiniMax) ---
MINIMAX_API_KEY=你的minimax密钥
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01
# 兼容变量（若只设 MINIMAX_* 则以下会自动使用）
LLM_API_KEY=${MINIMAX_API_KEY}
LLM_BASE_URL=${MINIMAX_BASE_URL}
LLM_MODEL=${MINIMAX_MODEL}

# --- LLM Fallback (DeepSeek) ---
DEEPSEEK_API_KEY=你的deepseek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 鉴权密钥 ---
JWT_SECRET_KEY=替换为随机字符串（至少32字符）
SECRET_KEY=替换为随机字符串（至少32字符）

# --- 运行参数 ---
UVICORN_WORKERS=2
FRONTEND_PORT=80
LOG_LEVEL=info
