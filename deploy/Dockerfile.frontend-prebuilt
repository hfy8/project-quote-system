# 前端镜像 - 直接打包本地 dist
FROM nginx:alpine

RUN rm /etc/nginx/conf.d/default.conf

# 复制本地构建好的 dist (不需要 node build)
COPY frontend/dist/ /usr/share/nginx/html/
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

# 不设 HEALTHCHECK: nginx:alpine 镜像没 wget/curl
# swarm 已用 task.running 状态判断就绪 (task 启动 + nginx daemon 监听 80 = healthy)

CMD ["nginx", "-g", "daemon off;"]
